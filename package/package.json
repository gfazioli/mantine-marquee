{
  "name": "@gfazioli/mantine-marquee",
  "version": "4.1.1",
  "description": "Mantine component that creates seamless, GPU-accelerated infinite-scrolling content loops — horizontal/vertical directions, responsive props, CSS-mask fade edges, and a 3D isometric variant.",
  "homepage": "https://gfazioli.github.io/mantine-marquee/",
  "packageManager": "yarn@4.0.1",
  "license": "MIT",
  "author": "Giovambattista Fazioli <giovambattista.fazioli@gmail.com>",
  "keywords": [
    "3d",
    "animation",
    "branding",
    "carousel",
    "component",
    "extension",
    "infinite-scroll",
    "isometric",
    "mantine",
    "mantine-ui",
    "mantine-v8",
    "marquee",
    "perspective",
    "react",
    "react-component",
    "scroll",
    "typescript"
  ],
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/esm/index.mjs",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/types/index.d.mts",
        "default": "./dist/esm/index.mjs"
      },
      "require": {
        "types": "./dist/types/index.d.ts",
        "default": "./dist/cjs/index.cjs"
      }
    },
    "./styles.css": "./dist/styles.css",
    "./styles.layer.css": "./dist/styles.layer.css"
  },
  "repository": "https://github.com/gfazioli/mantine-marquee.git",
  "peerDependencies": {
    "@mantine/core": ">=9.0.0",
    "@mantine/hooks": ">=9.0.0",
    "react": "^18.x || ^19.x",
    "react-dom": "^18.x || ^19.x"
  },
  "bugs": "https://github.com/gfazioli/mantine-marquee/issues"
}
